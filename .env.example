# ---- Core ----
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Database (Postgres) ----
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/marketplace?schema=public

# ---- Redis (for BullMQ jobs) ----
REDIS_URL=redis://localhost:6379

# ---- NextAuth ----
AUTH_SECRET=replace-with-openssl-rand-base64-32
AUTH_TRUST_HOST=true

# ---- Phone OTP (Twilio Verify) — Module 1 ----
# In dev, leave blank to use the stubbed OTP (code: 123456)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# ---- Object storage (S3 or R2) ----
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=marketplace-uploads
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=

# ---- Claude API (AI listings, search intent, translation) — Module 2/3 ----
ANTHROPIC_API_KEY=

# ---- Background removal (Remove.bg or self-hosted rembg) — Module 2 ----
REMOVE_BG_API_KEY=

# ---- Stripe (US-side payments) — Module 4 ----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ---- Razorpay (India payouts + optional bank linking) — Module 1/4 ----
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ---- Shiprocket X (logistics) — Module 5 ----
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=

# ---- KYC providers (GST / PAN / Udyam) — Module 1, optional ----
KYC_PROVIDER_API_KEY=

# ---- Sentry (error tracking, optional) ----
# Server-side DSN (Next.js server runtime + BullMQ worker).
SENTRY_DSN=
# Client-side DSN (browser bundle). Public — exposed to clients.
NEXT_PUBLIC_SENTRY_DSN=
# Environment tag (defaults to NODE_ENV).
SENTRY_ENVIRONMENT=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=
# Source-map upload (build time). All three needed for build-time integration.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
